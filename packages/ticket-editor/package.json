{
  "name": "@ticket-editor/vue",
  "version": "0.2.0",
  "description": "Embeddable Vue 3 ticket-format editor with a 1:1 wasm preview. Zero coupling to any host UI kit.",
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://rsansores.github.io/ticket-editor/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsansores/ticket-editor.git",
    "directory": "packages/ticket-editor"
  },
  "bugs": {
    "url": "https://github.com/rsansores/ticket-editor/issues"
  },
  "keywords": [
    "receipt",
    "thermal-printer",
    "ticket",
    "editor",
    "vue",
    "wasm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.5.0",
  "files": [
    "dist",
    "src/wasm"
  ],
  "main": "./dist/ticket-editor.cjs",
  "module": "./dist/ticket-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ticket-editor.js",
      "require": "./dist/ticket-editor.cjs"
    },
    "./styles.css": "./dist/ticket-editor.css"
  },
  "scripts": {
    "dev": "vite --host --port 5199",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "build:demo": "BUILD_DEMO=1 vite build",
    "build:wasm": "../../scripts/build-wasm.sh",
    "prepack": "pnpm run build:wasm && pnpm run build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"demo/**/*.{ts,vue}\""
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vue-i18n": "^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vue": "^3.5.13",
    "vue-eslint-parser": "^10.4.1",
    "vue-i18n": "^11.0.0",
    "vue-tsc": "^3.3.7"
  }
}
